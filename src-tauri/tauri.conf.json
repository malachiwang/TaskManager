{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TaskManagementOS",
  "identifier": "com.taskos.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "VITE_API_BASE=http://127.0.0.1:8765 npm --prefix ../frontend run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/taskos-server"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "TaskManagementOS",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
